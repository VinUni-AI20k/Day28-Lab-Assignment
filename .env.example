# Copy file này thành `.env` rồi điền giá trị thực.
# Tất cả URL ngrok lấy từ Kaggle Notebook (Cell 4) sau khi chạy vLLM + embedding.

# vLLM server chạy trên Kaggle GPU (Qwen2.5-7B-Instruct-GPTQ-Int4)
VLLM_NGROK_URL=https://REPLACE-WITH-YOUR-VLLM-NGROK.ngrok-free.app

# Embedding service (sentence-transformers) chạy trên Kaggle
EMBED_NGROK_URL=https://REPLACE-WITH-YOUR-EMBED-NGROK.ngrok-free.app

# LangSmith API key — smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=lsv2_pt_REPLACE_WITH_YOUR_KEY
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=lab28-platform
